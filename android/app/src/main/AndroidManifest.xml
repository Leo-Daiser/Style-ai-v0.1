<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

<!-- 
         SECURITY POLICY: For maximum user privacy under pure offline sandbox processing, 
         the INTERNET permission is intentionally disabled to ensure no image bytes or 
         style telemetry can leave the local execution context. 
         
         TODO: Reintroduce 'android.permission.INTERNET' only when transitioning StyleAI 
         to client-server modes with strict encryption protocols (HTTPS/TLS).
    -->

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="StyleAI"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
